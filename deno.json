{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/v1.41.0/cli/schemas/config-file.v1.json",
  "version": "0.2.1",
  "tasks": {
    "start": "deno run --watch --allow-read --allow-write --allow-env --unstable-temporal --allow-net --allow-sys --allow-run main.ts serve --watch --hot",
    "compile": "deno compile --target=$TARGET --allow-read --allow-write --allow-env --unstable-temporal --allow-net --allow-sys --allow-run --output gomi-$TARGET main.ts"
  },
  "imports": {
    "@deno/gfm": "jsr:@deno/gfm@^0.8.2",
    "@shikijs/rehype": "npm:@shikijs/rehype@1.22.2",
    "@std/async": "jsr:@std/async@1.0.8",
    "@std/cli": "jsr:@std/cli@^1.0.6",
    "@std/collections": "jsr:@std/collections@^1.0.9",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.2",
    "@std/encoding": "jsr:@std/encoding@^1.0.5",
    "@std/fmt": "jsr:@std/fmt@^1.0.3",
    "@std/front-matter": "jsr:@std/front-matter@^1.0.5",
    "@std/fs": "jsr:@std/fs@^1.0.5",
    "@std/http": "jsr:@std/http@^1.0.9",
    "@std/media-types": "jsr:@std/media-types@^1.0.3",
    "@std/net": "jsr:@std/net@^1.0.4",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/streams": "jsr:@std/streams@^1.0.8",
    "@std/toml": "jsr:@std/toml@^1.0.1",
    "@std/yaml": "jsr:@std/yaml@^1.0.5",
    "rehype-stringify": "npm:rehype-stringify@10.0.1",
    "remark-gfm": "npm:remark-gfm@4.0.0",
    "remark-parse": "npm:remark-parse@11.0.0",
    "remark-rehype": "npm:remark-rehype@11.1.1",
    "shiki": "npm:shiki@1.22.2",
    "unified": "npm:unified@11.0.5"
  }
}
